# Morphic deploy configuration — copy to ".env.deploy" and fill in.
# ".env.deploy" is gitignored. NEVER commit real credentials.

# --- Home Assistant SSH/SFTP target ---
MORPHIC_SSH_HOST=homeassistant.local
MORPHIC_SSH_PORT=22
MORPHIC_SSH_USER=root

# --- Authentication: choose ONE of the following ---
# Option A) Private key (recommended). Absolute path to your private key file.
MORPHIC_SSH_KEY=
# Optional passphrase if your key is encrypted.
MORPHIC_SSH_PASSPHRASE=
# Option B) Password auth (used only if MORPHIC_SSH_KEY is empty).
MORPHIC_SSH_PASSWORD=

# --- Remote target ---
# Where the built bundle is uploaded. Served by HA at /local/morphic/morphic.js
MORPHIC_REMOTE_PATH=/config/www/morphic

# --- Optional behaviour ---
# Set to "1" to skip strict host key checking (less secure; handy for first run).
MORPHIC_SSH_INSECURE=0
