{
  "name": "morphic-cards",
  "version": "0.1.0",
  "description": "Morphic — a Home Assistant first-party custom-card collection implementing Material 3 Expressive, built to be extended with Card-Mod.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "rimraf \"dist/morphic.js\" \"dist/morphic.js.map\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.mjs\"",
    "build": "npm run clean && rollup -c",
    "dev": "rollup -c -w",
    "deploy": "npm run build && node scripts/deploy.mjs",
    "deploy:dry": "node scripts/deploy.mjs --dry-run"
  },
  "dependencies": {
    "@material/material-color-utilities": "0.4.0",
    "lit": "3.3.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/node": "26.0.0",
    "chokidar": "5.0.0",
    "dotenv": "17.4.2",
    "eslint": "9.39.4",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "rollup": "4.62.2",
    "ssh2-sftp-client": "12.1.1",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1"
  }
}
